# Shared demo password (required for local access)
DEMO_PASSWORD=verdia-demo

# Optional: when set, BFF persists to Supabase instead of in-memory store
# Apply supabase/migrations/20260720120000_capturas_trechos.sql first
# Then apply supabase/migrations/20260720140000_capturas_inference_error.sql
# Then apply supabase/migrations/20260720160000_capturas_overlay.sql
SUPABASE_URL=
# Secret key from Dashboard → API Keys (sb_secret_…)
SUPABASE_SECRET_KEY=

# Simulador de ingestão (npm run simulate-ingest)
INFERENCE_URL=http://127.0.0.1:8000
# Required when the Inference API has INFERENCE_API_KEY set (e.g. Render)
INFERENCE_API_KEY=
WEB_URL=http://127.0.0.1:3000
# SAMPLE_MANIFEST=fixtures/capturas/manifest.json

# Optional: offline eval metrics for /observabilidade (JSON object)
# Needs at least accuracy and/or ordinalMae.
# Prefer contents of services/ml/data/eval_metrics.json after:
#   cd services/ml && uv run python scripts/evaluate_dnit.py
# Example: {"accuracy":0.82,"ordinalMae":0.31,"sampleCount":40,"evaluatedAt":"2026-07-20T09:00:00.000Z"}
# EVAL_METRICS_JSON=
