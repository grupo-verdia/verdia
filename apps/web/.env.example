# Shared demo password (required for local access)
DEMO_PASSWORD=verdia-demo

# Optional: when set, BFF persists to Supabase instead of in-memory store
# Apply supabase/migrations/20260720120000_capturas_trechos.sql first
# Then apply supabase/migrations/20260720140000_capturas_inference_error.sql
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Simulador de ingestão (npm run simulate-ingest)
INFERENCE_URL=http://127.0.0.1:8000
WEB_URL=http://127.0.0.1:3000
# SAMPLE_MANIFEST=fixtures/capturas/manifest.json
